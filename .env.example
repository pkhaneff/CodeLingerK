# =============================================================================
# CodeLingerK - Environment Configuration
# =============================================================================

# App
APP_NAME=CodeLingerK
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# GitHub OAuth (Create OAuth App at: https://github.com/settings/developers)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# GitLab OAuth (Create OAuth App at: https://gitlab.com/-/profile/applications)
# Scopes required: read_user, api, read_repository
# =============================================================================
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:8000/api/v1/auth/gitlab/callback
GITLAB_WEBHOOK_SECRET=

# =============================================================================
# Webhook Configuration
# Public URL where providers will send webhook events
# Example: https://your-domain.com or https://abc123.ngrok.io
# =============================================================================
WEBHOOK_BASE_URL=

# =============================================================================
# Databases
# =============================================================================

# PostgreSQL (stores all data including code graph)
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis
REDIS_URL=

# =============================================================================
# Security
# =============================================================================

JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Storage
# =============================================================================
REPO_STORAGE_PATH=

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Supported providers: claude, openai, deepseek, groq, custom
# For OpenAI-compatible providers, only change AI_PROVIDER, AI_API_KEY, AI_MODEL

# --- Option 1: OpenAI ---
AI_PROVIDER=openai
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o
# AI_BASE_URL= (not needed for OpenAI)

# --- Option 2: DeepSeek ---
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxx
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com

# --- Option 3: Groq ---
# AI_PROVIDER=groq
# AI_API_KEY=gsk_xxx
# AI_MODEL=llama-3.1-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1

# --- Option 4: Claude (Anthropic) ---
# AI_PROVIDER=claude
# AI_API_KEY=sk-ant-xxx
# AI_MODEL=claude-sonnet-4-20250514
# AI_BASE_URL= (not used for Claude)

# --- Option 5: Custom OpenAI-compatible provider ---
# AI_PROVIDER=custom
# AI_API_KEY=sk-xxx
# AI_MODEL=your-model-name
# AI_BASE_URL=https://your-api-endpoint.com/v1

# Common settings (optional)
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT=120
AI_MAX_RETRIES=3

# Legacy (deprecated - use AI_API_KEY instead)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
